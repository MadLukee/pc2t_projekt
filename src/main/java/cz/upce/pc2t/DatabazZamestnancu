package cz.upce.pc2t;

import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

public class DatabazZamestnancu {

    private final Map<Integer, Zamestnanec> zamestnanci;

    public DatabazZamestnancu() {
        this.zamestnanci = new HashMap<>();
    }

    public boolean pridatZamestnance(Zamestnanec zamestnanec) {
        if (zamestnanci.containsKey(zamestnanec.getId())) {
            return false;
        }
        zamestnanci.put(zamestnanec.getId(), zamestnanec);
        return true;
    }

    public Zamestnanec najitPodleId(int id) {
        return zamestnanci.get(id);
    }

    public List<Zamestnanec> vsichniZamestnanci() {
        return new ArrayList<>(zamestnanci.values());
    }

    public int pocetZamestnancu() {
        return zamestnanci.size();
    }

   public List<Zamestnanec> zamestnanciPodleSkupiny(String skupina) {
        List<Zamestnanec> vysledek = new ArrayList<>();
        for (Zamestnanec z : zamestnanci.values()) {
            if (z.getSkupina().equals(skupina)) {
                vysledek.add(z);
            }
        }
        return vysledek;
    }

    public boolean odstranit(int id) {
        Zamestnanec z = zamestnanci.remove(id);
        if (z == null) {
            return false;
        }

        for (Zamestnanec zamestnanec : zamestnanci.values()) {
            zamestnanec.getSpoluprace().removeIf(s -> s.getSpolupracovnik().getId() == id);
        }

        return true;
    }

public boolean pridatSpolupraci(int id1, int id2, UrovenSpoluprace uroven) {
        if (id1 == id2) {
            return false;
        }

        Zamestnanec z1 = najitPodleId(id1);
        Zamestnanec z2 = najitPodleId(id2);

        if (z1 == null || z2 == null) {
            return false;
        }

        for (Spoluprace s : z1.getSpoluprace()) {
            if (s.getSpolupracovnik().getId() == id2) {
                return false;
            }
        }

        z1.pridatSpolupraci(new Spoluprace(z2, uroven));
        z2.pridatSpolupraci(new Spoluprace(z1, uroven));
        return true;
    }

     public List<Zamestnanec> vsichniAbecedne() {
        List<Zamestnanec> seznam = new ArrayList<>(zamestnanci.values());
        seznam.sort((a, b) -> a.getPrijmeni().compareTo(b.getPrijmeni()));
        return seznam;
    }

    public List<Zamestnanec> skupinaPodleAbecedy(String skupina) {
        List<Zamestnanec> seznam = zamestnanciPodleSkupiny(skupina);
        seznam.sort((a, b) -> a.getPrijmeni().compareTo(b.getPrijmeni()));
        return seznam;
    }

     public Map<String, Object> ziskejStatistikyZamestnance(int id) {
        Zamestnanec z = najitPodleId(id);
        if (z == null) {
            return null;
        }

        Map<String, Object> statistiky = new HashMap<>();
        statistiky.put("jmeno", z.getJmeno());
        statistiky.put("prijmeni", z.getPrijmeni());
        statistiky.put("id", z.getId());
        statistiky.put("skupina", z.getSkupina());
        statistiky.put("rokNarozeni", z.getRokNarozeni());
        statistiky.put("pocetSpoluprace", z.getSpoluprace().size());

        Map<UrovenSpoluprace, Integer> poctyUroven = new HashMap<>();
        for (Spoluprace s : z.getSpoluprace()) {
            UrovenSpoluprace uroven = s.getUroven();
            poctyUroven.put(uroven, poctyUroven.getOrDefault(uroven, 0) + 1);
        }
        statistiky.put("poctyUroven", poctyUroven);

        if (!z.getSpoluprace().isEmpty()) {
            double soucet = 0;
            for (Spoluprace s : z.getSpoluprace()) {
                switch (s.getUroven()) {
                    case SPATNA -> soucet += 1.0;
                    case PRUMERNA -> soucet += 2.0;
                    case DOBRA -> soucet += 3.0;
                }
            }
            double priemer = soucet / z.getSpoluprace().size();
            statistiky.put("prumerSkore", priemer);
        }

        return statistiky;
    }
}
